# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NUNCA commitar (.env.example é a exceção permitida)
.env
.env.local
.env.development
.env.test
.env.production
.env*
!.env.example

# banco de dados local (contém hashes de senha e tokens de sessão)
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db
prisma/*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# documento de planejamento da integração Shopee — NÃO publicar (mantido só localmente)
docs/shopee-integracao-plano.md

# scripts de debug/verificação manual (não fazem parte do produto)
/debug*.mjs
/verify*.mjs
/teste_*.mjs

# arquivos de teste/relatório do Playwright
/test-results/
/playwright-report/
